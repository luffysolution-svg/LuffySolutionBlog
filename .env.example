# Public configuration bundled into the browser. This is not a secret.
NEXT_PUBLIC_GITHUB_COMMENTS_REPO=your-github-name/your-comments-repo
NEXT_PUBLIC_GITHUB_COMMENTS_LABEL=blog-comment

# Optional server-only integrations. Never commit real values.
GEMINI_API_KEY=
QWEATHER_KEY=

# Cross-device CMS. Never commit real values.
CMS_ADMIN_PASSWORD=
CMS_SESSION_SECRET=
CMS_GITHUB_REPO=your-github-name/your-blog-repo
CMS_GITHUB_BRANCH=main
# Leave empty when the Next.js app is the repository root.
CMS_GITHUB_ROOT=
CMS_GITHUB_TOKEN=
# Added automatically when a Vercel Blob store is connected.
BLOB_READ_WRITE_TOKEN=
